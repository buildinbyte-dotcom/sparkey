# Supabase project (create in the Sydney / ap-southeast-2 region)
# Found under Project Settings -> API Keys in the Supabase dashboard.
# Use the Publishable key (sb_publishable_...) — or the legacy anon key (eyJ...)
# on older projects. Never use the Secret key (sb_secret_...) here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key

# Base URL of the deployed app (used in auth email redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: enables the "Tidy with AI" question formatter on the ask page.
# Leave unset to hide the feature entirely. Server-side only — never exposed
# to the browser. Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional override; defaults to gpt-4.1-mini
OPENAI_MODEL=
